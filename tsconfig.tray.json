{
  "compilerOptions": {
    "target":              "ES2020",
    "module":              "CommonJS",
    "moduleResolution":    "node",
    "lib":                 ["ES2020"],
    "outDir":              "./tray-app/dist",
    "rootDir":             "./tray-app/src",
    "strict":              true,
    "esModuleInterop":     true,
    "skipLibCheck":        true,
    "resolveJsonModule":   true,
    "declaration":         false,
    "sourceMap":           false
  },
  "include": ["tray-app/src/**/*"]
}
